{
  "schemaVersion": 1,
  "id": "researcher",
  "version": "${version}",
  "name": "Researcher",
  "description": "A (mostly) data-driven research system inspired by Factorio.",
  "authors": ["Tr100000"],
  "contact": {
    "homepage": "https://modrinth.com/mod/researcher",
    "sources": "https://github.com/Tr100000/Researcher",
    "issues": "https://github.com/Tr100000/Researcher/issues"
  },
  "license": "MIT",
  "icon": "assets/researcher/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["io.github.tr100000.researcher.Researcher"],
    "client": ["io.github.tr100000.researcher.ResearcherClient"],
    "codec2schema:main": ["io.github.tr100000.researcher.compat.codec2schema.ResearcherSchemaPlugin"]
  },
  "custom": {
    "fzzy_config": ["researcher"]
  },
  "mixins": [
    "researcher.mixins.json",
    {
      "config": "researcher.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "researcher.classtweaker",
  "depends": {
    "fabricloader": ">=0.18",
    "minecraft": "~26.1-",
    "java": ">=25",
    "fabric-api": ">=0.143",
    "trutils": ">=0.1",
    "fzzy_config": ">=0.7.6"
  },
  "suggests": {
    "codec2schema": ">=0.2"
  }
}
